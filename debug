import streamlit as st
import google.generativeai as genai


genai.configure(
    api_key="AIzaSyDHVQZNo9N2O1tjOjYfj1QIoneTF2X5Jfw"
)

model = genai.GenerativeModel("models/gemini-1.5-flash")



def debug_code(code, language):

    prompt = f"""
    You are an expert software debugger.

    Analyze this {language} code and find:

    1. Syntax errors
    2. Logical errors
    3. Runtime issues
    4. Corrected code
    5. Optimization suggestions

    Code:
    {code}
    """

    response = model.generate_content(prompt)

    return response.text



st.title("🐞 AI Code Debugger (Gemini)")

language = st.selectbox(
    "Select Language",
    ["Python", "Java", "C", "C++", "JavaScript"]
)

code = st.text_area(
    "Paste Your Code",
    height=300
)

if st.button("Debug Code 🚀"):

    if code.strip() == "":
        st.warning("Please enter code")

    else:
        with st.spinner("Analyzing code..."):

            try:
                result = debug_code(code, language)
                st.markdown("### 🐞 Debug Result")
                st.write(result)

            except Exception as e:
                st.error(f"Error: {e}")
